  "settings": [
    {
      "type": "text",
      "id": "template_id",
      "label": "Product Template Code",
      "info": "The MeasureRight template code (e.g. roller-blind). Find this in your MeasureRight admin under Templates."
    },
    {
      "type": "checkbox",
      "id": "hide_default_controls",
      "label": "Hide default product controls",
      "info": "Hides Shopify's default variant picker, quantity input, and Add to Cart button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_from_price",
      "label": "Show 'From $X' minimum price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_fabric_selector",
      "label": "Show fabric & colour selector",
      "info": "Enable if your products require fabric selection. Leave off for simple dimension-based pricing.",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_breakdown",
      "label": "Show price breakdown",
      "info": "Show a line-by-line cost breakdown below the total price",
      "default": true
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Colour",
      "info": "Used for buttons, price highlight, and focus states",
      "default": "#2563eb"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "info": "Text shown on the Add to Cart button",
      "default": "Add to Cart"
    }
  ]
}
